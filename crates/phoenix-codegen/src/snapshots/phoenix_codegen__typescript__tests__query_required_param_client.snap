// Generated by Phoenix Gen — do not edit manually.

import type { User } from "./types";

export let baseUrl = "";

export function setBaseUrl(url: string): void {
  baseUrl = url;
}

export const api = {
  async searchUsers(opts: { term: string; page?: number }): Promise<User[]> {
    const params = new URLSearchParams();
    if (opts?.term !== undefined) params.set("term", String(opts.term));
    if (opts?.page !== undefined) params.set("page", String(opts.page));
    const query = params.toString();
    const response = await fetch(`${baseUrl}/api/users/search${query ? `?${query}` : ""}`, {
      method: "GET",
    });
    if (!response.ok) {
      throw new Error(`${response.status}: ${response.statusText}`);
    }
    return await response.json();
  },

}
