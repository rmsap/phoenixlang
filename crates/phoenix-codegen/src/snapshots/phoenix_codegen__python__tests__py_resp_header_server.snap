    @router.get("/api/posts/{id}")
    async def get_post(id: str, response: Response) -> Post:
        result = await handlers.get_post(id=id)
        response.headers["X-RateLimit-Remaining"] = str(result.ratelimit_remaining)
        return result.body

    return router
