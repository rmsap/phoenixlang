// Generated by Phoenix Gen — do not edit manually.

import { Router } from "express";
import type { Request, Response } from "express";
import type { Handlers } from "./handlers";

export function createRouter(handlers: Handlers): Router {
  const router = Router();

  router.post("/api/users", async (req: Request, res: Response) => {
    try {
      const body = req.body;
      const result = await handlers.createUser(body);
      res.json(result);
    } catch (error: unknown) {
      if (error instanceof Error) {
        if (error.message === "ValidationError") { res.status(400).json({ error: "ValidationError" }); return; }
        if (error.message === "Conflict") { res.status(409).json({ error: "Conflict" }); return; }
      }
      res.status(500).json({ error: "Internal Server Error" });
    }
  });

  return router;
}
