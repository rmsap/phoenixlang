// Generated by Phoenix Gen — do not edit manually.

import type { GetPostResult, Post } from "./types";

export let baseUrl = "";

export function setBaseUrl(url: string): void {
  baseUrl = url;
}

export const api = {
  async getPost(id: string): Promise<GetPostResult> {
    const response = await fetch(`${baseUrl}/api/posts/${id}`, {
      method: "GET",
    });
    if (!response.ok) {
      throw new Error(`${String(response.status)}: ${response.statusText}`);
    }
    return {
      body: (await response.json()) as Post,
      ratelimitRemaining: Number(response.headers.get("X-RateLimit-Remaining")),
      requestId: response.headers.get("Request-Id") ?? undefined,
    };
  },
};
