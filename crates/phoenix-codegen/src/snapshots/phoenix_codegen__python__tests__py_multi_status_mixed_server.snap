# Generated by Phoenix Gen — do not edit manually.

from fastapi import APIRouter, Response

from .handlers import Handlers


def create_router(handlers: Handlers) -> APIRouter:
    router = APIRouter()

    @router.put("/api/users/{id}")
    async def update_user(id: str) -> Response:
        result = await handlers.update_user(id=id)
        if result.status not in (200, 204):
            return Response(
                content="handler returned undeclared status", status_code=500
            )
        if result.status in (200,) and result.body is None:
            return Response(
                content="handler returned no body for a typed status", status_code=500
            )
        if result.status in (204,) and result.body is not None:
            return Response(
                content="handler returned a body for a bodyless status", status_code=500
            )
        if result.body is not None:
            return Response(
                content=result.body.model_dump_json(by_alias=True),
                status_code=result.status,
                media_type="application/json",
            )
        return Response(status_code=result.status)

    return router
