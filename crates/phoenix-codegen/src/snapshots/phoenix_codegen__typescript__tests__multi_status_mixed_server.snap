// Generated by Phoenix Gen — do not edit manually.

import { Router } from "express";
import type { Request, Response } from "express";
import type { Handlers } from "./handlers";

export function createRouter(handlers: Handlers): Router {
  const router = Router();

  router.put(
    "/api/users/:id",
    async (req: Request<{ id: string }>, res: Response) => {
      try {
        const id = req.params.id;
        const result = await handlers.updateUser(id);
        if (![200, 204].includes(result.status)) {
          res.status(500).json({ error: "handler returned undeclared status" });
          return;
        }
        if ([200].includes(result.status) && result.body === undefined) {
          res
            .status(500)
            .json({ error: "handler returned no body for a typed status" });
          return;
        }
        if ([204].includes(result.status) && result.body !== undefined) {
          res
            .status(500)
            .json({ error: "handler returned a body for a bodyless status" });
          return;
        }
        if (result.body !== undefined) {
          res.status(result.status).json(result.body);
        } else {
          res.status(result.status).end();
        }
      } catch {
        res.status(500).json({ error: "Internal Server Error" });
      }
    },
  );

  return router;
}
