# Generated by Phoenix Gen — do not edit manually.

import httpx
from .models import CreateUserBody, User


class ApiClient:
    def __init__(self, base_url: str) -> None:
        self.base_url = base_url
        self.client = httpx.AsyncClient()
    async def list_users(self) -> list[User]:
        response = await self.client.get(f"{self.base_url}/api/users")
        response.raise_for_status()
        return [User(**item) for item in response.json()]

    async def create_user(self, body: CreateUserBody) -> User:
        response = await self.client.post(f"{self.base_url}/api/users", json=body.model_dump())
        response.raise_for_status()
        return User(**response.json())

    async def get_user(self, id: str) -> User:
        response = await self.client.get(f"{self.base_url}/api/users/{id}")
        response.raise_for_status()
        return User(**response.json())

    async def delete_user(self, id: str) -> None:
        response = await self.client.delete(f"{self.base_url}/api/users/{id}")
        response.raise_for_status()
