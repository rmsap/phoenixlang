import type { Comment } from "./types";

export let baseUrl = "";

export function setBaseUrl(url: string): void {
  baseUrl = url;
}

export const api = {
  async getComment(userId: string, postId: string): Promise<Comment> {
    const response = await fetch(`${baseUrl}/api/users/${userId}/posts/${postId}`, {
      method: "GET",
    });
    if (!response.ok) {
      throw new Error(`${response.status}: ${response.statusText}`);
    }
    return await response.json();
  },

}
