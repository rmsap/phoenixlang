}

export const api = {
  async getStatus(): Promise<Status> {
    const response = await fetch(`${baseUrl}/api/status`, {
      method: "GET",
    });
    if (!response.ok) {
      throw new Error(`${response.status}: ${response.statusText}`);
    }
    return await response.json();
  },

