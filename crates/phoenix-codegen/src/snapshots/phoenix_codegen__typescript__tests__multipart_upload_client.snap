import type { UploadAvatarBody, UploadResult } from "./types";

export let baseUrl = "";

export function setBaseUrl(url: string): void {
  baseUrl = url;
}

export const api = {
  async uploadAvatar(body: UploadAvatarBody): Promise<UploadResult> {
    const formData = new FormData();
    formData.append("avatar", body.avatar);
    formData.append("caption", String(body.caption));
    const response = await fetch(`${baseUrl}/api/avatar`, {
      method: "POST",
      body: formData,
    });
    if (!response.ok) {
      throw new Error(`${String(response.status)}: ${response.statusText}`);
    }
    return (await response.json()) as UploadResult;
  },
};
