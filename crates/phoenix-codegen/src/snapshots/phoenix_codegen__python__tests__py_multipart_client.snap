# Generated by Phoenix Gen — do not edit manually.

from typing import Any

import httpx

from .models import FileUpload, UploadResult


class ApiClient:
    def __init__(self, base_url: str) -> None:
        self.base_url = base_url
        self.client = httpx.AsyncClient()

    async def upload_avatar(self, avatar: FileUpload, caption: str) -> UploadResult:
        files: dict[str, tuple[str, bytes]] = {}
        data: dict[str, Any] = {}
        files["avatar"] = (avatar.filename, avatar.content)
        data["caption"] = caption
        response = await self.client.post(
            f"{self.base_url}/api/avatar", files=files, data=data
        )
        response.raise_for_status()
        return UploadResult(**response.json())
