# Phoenix project configuration.
#
# Copy this file to phoenix.toml in your project root. The [gen] section
# configures `phoenix gen` defaults. The [package] and [dependencies]
# sections declare the package-manager manifest: `phoenix build`/`run`/`check`
# resolve and fetch declared dependencies (pinning git sources in phoenix.lock)
# before compiling, and `phoenix init`/`add` scaffold and edit this file.
# [js-dependencies] declares the npm packages an `extern js "pkg"` block binds.

# ── Package metadata ───────────────────────────────────────────
# Identifies this package so it can be depended upon (and, eventually,
# published). When present, `name` and `version` (semver) are required and
# the rest are optional. Uncomment this section to make the project a
# depend-able package; leave it commented for a schema-only project that
# just uses [gen].
#
# [package]
# name = "my-app"
# version = "0.1.0"
# description = "An example Phoenix package"
# authors = ["Ada <ada@example.com>"]
# license = "MIT"

# ── Dependencies ───────────────────────────────────────────────
# Each dependency is a git source or a local path source. An import's
# first path segment is matched against these names first, then local
# modules (a local module colliding with a dependency name is an error).
# A bare version string (e.g. `http = "^1.2"`) is reserved for a future
# registry and currently errors with "no registry configured".
#
# [dependencies]
# # Git source — pin with exactly one of tag / rev / branch (or omit for
# # the remote's default branch). The resolved commit is recorded in
# # phoenix.lock so builds are reproducible.
# http = { git = "https://github.com/example/phoenix-http.git", tag = "v1.2.3" }
# # Local path source — relative to this file's directory. Resolves in
# # place and is never SHA-pinned; ideal for monorepos and local dev.
# util = { path = "../util" }

# ── JavaScript dependencies ────────────────────────────────────
# npm packages an `extern js "pkg" { ... }` block binds. Each entry is
# an npm package name → a version spec, passed through verbatim (npm
# owns the version grammar; Phoenix does not interpret it).
#
# Phoenix records these; it does not install them. A wasm build writes a
# package.json from this section beside the generated JS glue — only if
# one is not already there, so your own package.json is never clobbered —
# and `npm install` in that directory supplies the actual code. On a wasm
# build, binding a module that isn't declared here is a warning, not an
# error: the host may legitimately come from a local module, an import
# map, or a bundler alias. (Other targets bind extern hosts directly, not
# via npm, so they skip the check.)
#
# [js-dependencies]
# left-pad = "^1.3.0"
# chalk = "^5"

[gen]
# Path to your .phx schema file.
schema = "api/schema.phx"

# ── Single target ──────────────────────────────────────────────
# Uncomment these for simple single-target generation:
#
# target = "typescript"       # typescript, python, go, openapi
# out_dir = "./generated"
# mode = "both"               # "client", "server", or "both"

# ── Multiple targets ───────────────────────────────────────────
# Use [gen.targets.<name>] sections to generate code for several
# languages in one `phoenix gen` invocation.

[gen.targets.typescript]
out_dir = "frontend/src/generated"
mode = "client"                     # types + client SDK only

[gen.targets.python]
out_dir = "backend/generated"
mode = "server"                     # types + handlers + router only

[gen.targets.openapi]
out_dir = "docs"
