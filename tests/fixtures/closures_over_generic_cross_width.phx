// Closures returned from generic functions at *different-width* type
// instantiations (e.g. Int → 1 slot, String → 2-slot fat pointer).
//
// Historically broken in `phoenix build`: the inner closure function was
// shared across all specializations of its enclosing generic, so each
// `makeAppender<T>` specialization's `Op::ClosureAlloc` pointed at the
// same `FuncId`, and Pass D erased its TypeVar-bearing `capture_types`
// to the `__generic` placeholder. Cranelift's `TypeLayout::of` mapped
// `__generic` to a 1-slot fallback, so `makeAppender<Int>` accidentally
// worked while `makeAppender<String>` mis-sized the 2-slot fat pointer
// (wild allocation). `phoenix run` / `phoenix run-ir` were unaffected
// (they dispatch on runtime value shape, not a static layout).
//
// **Fixed:** monomorphization now clones the closure function per
// enclosing-generic substitution (following `Op::ClosureAlloc` edges),
// so each specialization carries concrete `capture_types` and a concrete
// `Op::ClosureLoadCapture` result type. All three backends — `phoenix
// run`, `phoenix run-ir`, and `phoenix build` (native + wasm32-linear) —
// agree on `15\nhi:there\n`. See `docs/known-issues.md`.

function makeAppender<T>(seed: T, combiner: (T, T) -> T) -> (T) -> T {
  return function(x: T) -> T { combiner(seed, x) }
}

function main() {
  // 1-slot capture (Int) — currently works under all three backends.
  let bumpInt: (Int) -> Int = makeAppender(
    10,
    function(a: Int, b: Int) -> Int { a + b }
  )
  print(bumpInt(5))

  // 2-slot capture (String) — `phoenix build` mis-sizes the closure
  // heap object and aborts in the runtime allocator. Tree-walk and
  // IR-interp produce "hi:there".
  let bumpStr: (String) -> String = makeAppender(
    "hi:",
    function(a: String, b: String) -> String { a + b }
  )
  print(bumpStr("there"))
}
