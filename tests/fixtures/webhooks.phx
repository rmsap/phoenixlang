// Phoenix Gen — a realistic Webhooks API
//
// Two halves: (1) INBOUND receivers that accept events POSTed to us by an
// upstream provider, authenticated by a signature header (and a timestamp
// header to bound replay windows); and (2) OUTBOUND subscription management —
// CRUD over the subscriptions we deliver to, plus the delivery/attempt records.
//
// TYPE-MODELING NOTES: Phoenix Gen has no native DateTime/UUID/bytes/Decimal
// type, so timestamps are Unix epoch SECONDS (`Int`), all ids are opaque
// `String`s, the raw signature/secret are `String`s, and there is no first-class
// "URL" type so destination URLs are validated `String`s.

// ── Domain enums (simple unit-variant only — codegens on all 4 targets) ──

/** The kind of event carried by an inbound webhook or selected in a
 *  subscription's filter list */
enum EventType {
    ChargeSucceeded
    ChargeFailed
    ChargeRefunded
    SubscriptionCreated
    SubscriptionUpdated
    SubscriptionCanceled
    InvoicePaid
    InvoiceFailed
}

/** Lifecycle status of a single outbound delivery attempt */
enum DeliveryStatus { Pending  Delivered  Failed  Retrying  Dropped }

/** Whether a subscription is actively receiving deliveries */
enum SubscriptionState { Active  Paused  Disabled }

/** Verdict a receiver returns after validating an inbound signed event */
enum AckOutcome { Accepted  Duplicate  Ignored }

// ── Domain structs ────────────────────────────────────────────

/** A signed event as RECEIVED from the upstream provider. The provider signs
 *  the raw body; we re-expose the parsed envelope here */
struct InboundEvent {
    /** Opaque provider event id (no native UUID type — using String) */
    id: String where self.length > 0
    eventType: EventType
    /** Provider account/tenant this event belongs to */
    accountId: String where self.length > 0
    /** Event creation time as Unix epoch SECONDS. No native DateTime type */
    createdAt: Int where self >= 0
    /** Monotonic schema version of the event payload */
    apiVersion: Int where self >= 1
    /** Flattened, stringified payload (no native JSON/Any type — Map of
     *  String→String keeps it codegen-safe across targets) */
    data: Map<String, String>
    /** True when re-sent by the provider after a prior delivery failed */
    resent: Bool
}

/** A destination we deliver outbound events to */
struct Subscription {
    /** Opaque subscription id (no native UUID type — using String) */
    id: String where self.length > 0
    /** Human-readable label for dashboards */
    description: String where self.length <= 200
    /** HTTPS destination URL (no native URL type — validated String) */
    url: String where self.contains("https://") && self.length > 8
    state: SubscriptionState
    /** The event types this destination is subscribed to. Empty = all events */
    eventTypes: List<EventType>
    /** Shared secret used to sign our outbound deliveries to this URL */
    secret: String where self.length >= 16
    /** Custom headers injected on every delivery to this destination */
    customHeaders: Map<String, String>
    /** Creation time as Unix epoch SECONDS. No native DateTime type */
    createdAt: Int where self >= 0
}

/** One delivery attempt of one event to one subscription */
struct Delivery {
    /** Opaque delivery id (no native UUID type — using String) */
    id: String where self.length > 0
    /** The subscription this delivery targets */
    subscriptionId: String where self.length > 0
    /** The source event being delivered */
    eventId: String where self.length > 0
    eventType: EventType
    status: DeliveryStatus
    /** Number of attempts made so far */
    attempts: Int where self >= 0
    /** HTTP status code returned by the destination on the last attempt, if any.
     *  No numeric `where` here: a constraint on an `Option<Int>` cannot compare
     *  the optional to an Int (sema rejects `Option<Int> >= Int`) */
    responseCode: Option<Int>
    /** Truncated response body captured from the destination, if any */
    responseBody: Option<String> where self.length > 0
    /** Unix epoch SECONDS of the next scheduled retry, if still retrying */
    nextRetryAt: Option<Int>
    /** Creation time as Unix epoch SECONDS. No native DateTime type */
    createdAt: Int where self >= 0
}

/** The acknowledgement a receiver returns after validating an inbound event */
struct AckReceipt {
    /** Echoes the provider event id we accepted */
    eventId: String where self.length > 0
    outcome: AckOutcome
    /** Our internal ingestion id assigned to the accepted event, if stored */
    ingestId: Option<String> where self.length > 0
    /** Receipt time as Unix epoch SECONDS. No native DateTime type */
    receivedAt: Int where self >= 0
}

// ── Inbound receiver endpoints (signature + timestamp headers) ──

/** Generic inbound receiver: the provider POSTs a signed event here. We verify
 *  the X-Webhook-Signature against the raw body and reject stale timestamps.
 *  Returns 200 (accepted + processed inline) or 202 (accepted, queued for async
 *  processing) — both carry the same AckReceipt body, per the multi-status rule
 *  that all typed entries share one type */
endpoint receiveEvent: POST "/webhooks/inbound" {
    headers {
        signature: String as "X-Webhook-Signature"
        timestamp: Int as "X-Webhook-Timestamp"
        idempotencyKey: Option<String> as "X-Idempotency-Key"
    }
    body InboundEvent
    response {
        200: AckReceipt
        202: AckReceipt
    }
    error {
        BadRequest(400)
        InvalidSignature(401)
        Conflict(409)
    }
}

/** Provider-specific receiver using the legacy `X-Signature` header name. Returns
 *  200 (accepted + processed) or 204 (accepted, nothing to do) — both typeless,
 *  so clients must detect the empty body by CONTENT, not by the status code */
endpoint receiveLegacyEvent: POST "/webhooks/inbound/legacy" {
    headers {
        signature: String as "X-Signature"
        timestamp: Option<Int> as "X-Signature-Timestamp"
    }
    body InboundEvent
    response {
        200
        204
    }
    error {
        BadRequest(400)
        InvalidSignature(401)
    }
}

// ── Subscription management (CRUD with omit/pick/partial bodies) ──

/** Create a subscription. Server assigns id/state/createdAt, so omit them */
endpoint createSubscription: POST "/subscriptions" {
    headers {
        authorization: String
        idemKey: String as "Idempotency-Key"
    }
    body Subscription omit { id, state, createdAt }
    response Subscription
    error {
        BadRequest(400)
        Unauthorized(401)
        Conflict(409)
    }
}

/** Fetch a subscription by id */
endpoint getSubscription: GET "/subscriptions/{id}" {
    headers {
        authorization: String
    }
    response Subscription
    error {
        Unauthorized(401)
        NotFound(404)
    }
}

/** List subscriptions (offset-paginated), optionally filtered by event type */
endpoint listSubscriptions: GET "/subscriptions" {
    headers {
        authorization: String
    }
    query {
        page: Int = 1
        limit: Int = 20
        eventType: Option<String>
        activeOnly: Bool = false
    }
    response List<Subscription>
    pagination { offset }
    error { Unauthorized(401) }
}

/** Full replace of a subscription's mutable fields */
endpoint updateSubscription: PUT "/subscriptions/{id}" {
    headers {
        authorization: String
    }
    body Subscription omit { id, createdAt }
    response Subscription
    error {
        BadRequest(400)
        Unauthorized(401)
        NotFound(404)
    }
}

/** Partial update — every mutable field optional (e.g. flip state, swap URL) */
endpoint patchSubscription: PATCH "/subscriptions/{id}" {
    headers {
        authorization: String
    }
    body Subscription omit { id, createdAt } partial
    response Subscription
    error {
        BadRequest(400)
        Unauthorized(401)
        NotFound(404)
    }
}

/** Rotate a subscription's signing secret — only the secret is editable here */
endpoint rotateSecret: PATCH "/subscriptions/{id}/secret" {
    headers {
        authorization: String
    }
    body Subscription pick { secret }
    response Subscription
    error {
        BadRequest(400)
        Unauthorized(401)
        NotFound(404)
    }
}

/** Delete a subscription */
endpoint deleteSubscription: DELETE "/subscriptions/{id}" {
    headers {
        authorization: String
    }
    error {
        Unauthorized(401)
        NotFound(404)
    }
}

// ── Delivery / attempt records ────────────────────────────────

/** List the delivery attempts for a subscription (cursor-paginated), optionally
 *  filtered by status */
endpoint listDeliveries: GET "/subscriptions/{id}/deliveries" {
    headers {
        authorization: String
    }
    query {
        cursor: Option<String>
        limit: Int = 20
        status: Option<String>
    }
    response List<Delivery>
    pagination { cursor }
    error {
        Unauthorized(401)
        NotFound(404)
    }
}

/** Fetch a single delivery record by id */
endpoint getDelivery: GET "/deliveries/{id}" {
    headers {
        authorization: String
    }
    response Delivery
    error {
        Unauthorized(401)
        NotFound(404)
    }
}

/** Replay/retry a failed delivery. Returns 200 (re-attempt scheduled, fresh
 *  Delivery returned) or 202 (queued for async retry — same Delivery body).
 *  Both typed entries share the one Delivery type, per the multi-status rule */
endpoint replayDelivery: POST "/deliveries/{id}/replay" {
    headers {
        authorization: String
        idemKey: String as "Idempotency-Key"
    }
    response {
        200: Delivery
        202: Delivery
    }
    error {
        Unauthorized(401)
        NotFound(404)
        Conflict(409)
    }
}

// ── API versioning (v1 path-prefix block) ─────────────────────

/** A versioned slice: everything here is served under the `/v1` prefix */
api version "v1" {
    /** Test a subscription end-to-end: send a synthetic event to the
     *  destination and return the resulting Delivery, with rate-limit info
     *  surfaced via response headers */
    endpoint testSubscription: POST "/subscriptions/{id}/test" {
        headers {
            authorization: String
        }
        query {
            eventType: Option<String>
        }
        response Delivery headers {
            ratelimitRemaining: Int as "X-RateLimit-Remaining"
            requestId: Option<String> as "X-Request-Id"
        }
        error {
            Unauthorized(401)
            NotFound(404)
        }
    }
}
