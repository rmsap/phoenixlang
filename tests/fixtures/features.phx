// Showcase of Phoenix language features

struct Point {
  Int x
  Int y

  function display(self) -> String {
    "({self.x}, {self.y})"
  }
}

enum Shape {
  Circle(Float)
  Rect(Float, Float)

  function describe(self) -> String {
    match self {
      Circle(r) -> "Circle with radius {r}"
      Rect(w, h) -> "Rect {w}x{h}"
    }
  }
}

function main() {
  // While loop with compound assignment
  let mut sum: Int = 0
  let mut i: Int = 1
  while i <= 10 {
    sum += i
    i += 1
  }
  print(sum)

  // For loop with compound assignment
  let mut total: Int = 0
  for j in 0..5 {
    total += j
  }
  print(total)

  // Else if
  let x: Int = 42
  if x < 0 {
    print("negative")
  } else if x == 0 {
    print("zero")
  } else if x < 100 {
    print("small")
  } else {
    print("large")
  }

  // Struct
  let p: Point = Point(3, 4)
  print(p.x)
  print(p.display())

  // Enum + match
  let s1: Shape = Circle(3.14)
  let s2: Shape = Rect(5.0, 10.0)
  print(s1.describe())
  print(s2.describe())

  // Match with wildcard
  let s3: Shape = Circle(1.0)
  match s3 {
    Rect(_, _) -> print("rect")
    _ -> print("not a rect")
  }
}
