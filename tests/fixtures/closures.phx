// Closures with String captures + indirect call through a function
// parameter. Exercises the closure ABI: function pointer + heap
// capture record, fat-pointer String captures, and indirect-call
// dispatch via the env-pointer calling convention.

function applyTwice(f: (Int) -> Int, x: Int) -> Int {
  f(f(x))
}

function main() {
  let prefix: String = "result: "
  // Closure capturing a fat-pointer String.
  let say = function(name: String) -> String {
    prefix + name
  }
  print(say("alice"))
  print(say("bob"))

  // Indirect call through a function-typed parameter.
  let double = function(x: Int) -> Int { x * 2 }
  print(applyTwice(double, 3))

  // Closure capturing BOTH an 8-byte-aligned Int and a fat-pointer
  // String, so the capture layout has to pad past the 4-byte
  // fn-table-idx to land the Int on its natural 8-byte boundary and
  // walk a multi-capture offset accumulation (not just the single,
  // already-aligned String capture above).
  let base: Int = 10
  let label: String = "combined: "
  let combine = function(n: Int) -> String {
    label + toString(base + n)
  }
  print(combine(5))
}
