// Phoenix Gen — a realistic REST API for a blog platform

// ── Domain types ──────────────────────────────────────────────

struct Author {
    id: Int
    name: String where self.length > 0 && self.length <= 100
    email: String where self.contains("@") && self.length > 3
    avatarUrl: Option<String> where self.length > 0
}

enum PostStatus { Draft  Published  Archived }

struct Post {
    id: Int
    title: String where self.length > 0 && self.length <= 200
    body: String where self.length > 0
    author: Author
    status: PostStatus
    tags: List<String>
}

struct Comment {
    id: Int
    postId: Int
    text: String where self.length > 0 && self.length <= 2000
    authorName: String where self.length > 0
    parentId: Option<Int>
}

/** One entry of a Catalog — a struct nested inside a list field, itself carrying
 *  an enum, so the round-trip covers nested list-of-struct (and enum-in-struct). */
struct CatalogEntry {
    key: String where self.length > 0
    status: PostStatus
}

/** A catalog payload exercising the three composite type shapes the rest of
 *  gen_api.phx doesn't round-trip: a `Map<String, String>`, a `List<enum>`, and
 *  a `List<struct>` as a FIELD (not a top-level list response).
 *
 *  Also carries two reserved-word field names: `class`/`async` are valid Phoenix
 *  identifiers but Python keywords, so the Python generator escapes them to
 *  `class_`/`async_` and — carrying no alias — serializes by that escaped name, so
 *  the Python WIRE key diverges from Go/TS (Go capitalizes to `Class`/`Async` with
 *  a `class`/`async` JSON tag; TS keeps them verbatim as object properties). Echoed
 *  through syncCatalog, the round-trip proves the escaped Python field serializes
 *  and decodes on every target — the one reserved-word behavior compile-lint alone
 *  can't catch (see design-decisions.md, "reserved-word handling"). */
struct Catalog {
    id: Int
    labels: Map<String, String>
    allowedStatuses: List<PostStatus>
    entries: List<CatalogEntry>
    class: String
    async: Bool
}

// ── Endpoints ─────────────────────────────────────────────────

/** List published posts with pagination and optional tag filter */
endpoint listPosts: GET "/api/posts" {
    query {
        page: Int = 1
        limit: Int = 20
        tag: Option<String>
        search: Option<String>
        featured: Bool = false
        minScore: Float = 0.0
        maxScore: Option<Float>
    }
    response List<Post>
}

/** Get a single post by ID */
endpoint getPost: GET "/api/posts/{id}" {
    response Post
    error { NotFound(404) }
}

/**
 * Search posts by free-text query.
 * Required, camelCase query params force a Query alias on the Python server,
 * and this multi-line doc comment exercises multi-line comment rendering
 */
endpoint searchPosts: GET "/api/search" {
    query {
        maxResults: Int
        sortField: String
    }
    response List<Post>
}

/** Create a new post (omit server-generated fields) */
endpoint createPost: POST "/api/posts" {
    body Post omit { id, author } partial { tags }
    response Post
    error {
        ValidationError(400)
        Unauthorized(401)
    }
}

/** Full update — replace all mutable fields */
endpoint updatePost: PUT "/api/posts/{id}" {
    body Post omit { id, author }
    response Post
    error {
        NotFound(404)
        ValidationError(400)
        Unauthorized(401)
    }
}

/** Partial update — every field is optional */
endpoint patchPost: PATCH "/api/posts/{id}" {
    body Post omit { id, author } partial
    response Post
    error {
        NotFound(404)
        ValidationError(400)
        Unauthorized(401)
    }
}

/** Delete a post */
endpoint deletePost: DELETE "/api/posts/{id}" {
    error {
        NotFound(404)
        Unauthorized(401)
    }
}

// ── Comments (nested under posts) ─────────────────────────────

/** List comments for a post */
endpoint listComments: GET "/api/posts/{postId}/comments" {
    query {
        page: Int = 1
        limit: Int = 50
    }
    response List<Comment>
    error { NotFound(404) }
}

/** Add a comment to a post */
endpoint createComment: POST "/api/posts/{postId}/comments" {
    body Comment omit { id, postId, parentId }
    response Comment
    error {
        NotFound(404)
        ValidationError(400)
    }
}

// ── Author management (pick for a lightweight profile) ────────

/** Get the public profile for an author */
endpoint getAuthorProfile: GET "/api/authors/{id}" {
    response Author
    error { NotFound(404) }
}

/** Update author profile — only name and avatar are editable */
endpoint updateAuthorProfile: PATCH "/api/authors/{id}" {
    body Author pick { name, avatarUrl } partial { avatarUrl }
    response Author
    error {
        NotFound(404)
        ValidationError(400)
        Unauthorized(401)
    }
}

// ── Headers (request + response) ──────────────────────────────

/**
 * Fetch a post with request + response headers.
 * Exercises: an auto-derived wire name (`authorization` -> Authorization), an
 * explicit `as` override (X-Request-Id), an optional request header, a request
 * header with a default, and a response-header envelope (a required Int + an
 * optional String response header, one of which uses an `as` override).
 */
endpoint getPostMetered: GET "/api/posts/{id}/metered" {
    headers {
        authorization: String
        requestId: String as "X-Request-Id"
        ifNoneMatch: Option<String>
        maxStale: Int = 60
    }
    response Post headers {
        ratelimitRemaining: Int as "X-RateLimit-Remaining"
        etag: Option<String>
    }
    error { NotFound(404) }
}

// ── File upload / download (multipart + binary) ───────────────

/** A multipart avatar upload: a binary file plus scalar form fields.
 *
 * `rotation` (Int) and `crop` (Bool) exercise the per-target scalar coercion
 * paths end-to-end — client `data`/FormData stringification (notably bool →
 * `"true"`/`"false"`) and server `strconv.ParseInt`/`ParseBool` (Go),
 * `Form(...)` (Python), `Number(...)`/`=== "true"` (TS). */
struct AvatarUpload {
    avatar: File
    caption: String where self.length > 0
    rotation: Int
    crop: Bool
    thumbnail: Option<File>
}

/** A pure binary download body (exactly one File field). */
struct FileDownload {
    data: File
}

/** Upload an avatar via multipart/form-data (file + caption + optional thumbnail). */
endpoint uploadAvatar: POST "/api/authors/{id}/avatar" {
    body AvatarUpload
    response Author
    error {
        ValidationError(400)
        Unauthorized(401)
    }
}

/** Download an author's avatar as a binary stream. */
endpoint downloadAvatar: GET "/api/authors/{id}/avatar" {
    response FileDownload
    error { NotFound(404) }
}

// ── Pagination (offset + cursor envelopes) ────────────────────

/**
 * Offset-paginated post listing. The `pagination { offset }` block makes the
 * response a `ListPostsOffsetPage` envelope: { items: List<Post>, totalCount }.
 * The page/limit inputs are ordinary query params (Approach 2 — the user owns
 * the inputs; the block governs only the response envelope).
 */
endpoint listPostsOffset: GET "/api/posts/paged" {
    query {
        page: Int = 1
        limit: Int = 20
    }
    response List<Post>
    pagination { offset }
    error { NotFound(404) }
}

/**
 * Cursor-paginated post listing. The `pagination { cursor }` block makes the
 * response a `ListPostsCursorPage` envelope: { items: List<Post>, nextCursor? }
 * (nextCursor absent/null = last page).
 */
endpoint listPostsCursor: GET "/api/posts/feed" {
    query {
        cursor: Option<String>
        limit: Int = 20
    }
    response List<Post>
    pagination { cursor }
}

// ── Multi-status responses (shared body + typeless) ───────────

/**
 * Create-or-update a post: returns 200 (updated existing) or 201 (created new),
 * both carrying the same Post body, 202 (accepted for async processing — no
 * body), or 204 (no change). The `response { }` block makes the handler/client
 * use the `UpsertPost2Response` envelope { status: Int, body: Option<Post> } —
 * the handler picks the status, the client reads it back. The typeless 202
 * deliberately sits alongside 204: clients must detect an empty body by
 * CONTENT, not by special-casing the 204 status code.
 */
endpoint upsertPost2: PUT "/api/posts2/{id}" {
    body Post omit { id, author }
    response {
        200: Post
        201: Post
        202
        204
    }
    error {
        ValidationError(400)
        Unauthorized(401)
    }
}

/**
 * Re-queue a post for background processing: returns 202 (accepted — queued
 * for reprocessing) or 204 (no-op — already queued). An ALL-TYPELESS block:
 * no typed status, so the `RequeuePostResponse` envelope is just
 * { status: Int } with no body field — a distinct codegen branch (no body
 * decode in the client, no body write in the server) that the mixed
 * upsertPost2 endpoint cannot reach.
 */
endpoint requeuePost: POST "/api/posts/{id}/requeue" {
    response {
        202
        204
    }
}

/**
 * Round-trips a Catalog in (request body) and back out (response), so the three
 * composite shapes (Map, List<enum>, nested List<struct>) are exercised on both
 * the client->server and server->client legs. The handler echoes the decoded
 * body, so one deep-equality assertion proves both directions at once.
 */
endpoint syncCatalog: POST "/api/catalog" {
    body Catalog
    response Catalog
}

// ── API versioning (path-prefix block) ────────────────────────

/**
 * A versioned slice of the API: every endpoint here is served under the
 * `/v2` path prefix (e.g. listTaggedPosts -> /v2/api/posts/tagged). Exercises
 * the `api version "..." { }` block and the path-prefix resolution.
 */
api version "v2" {
    /** List posts filtered by tag, under the v2 prefix. */
    endpoint listTaggedPosts: GET "/api/posts/tagged/{tag}" {
        query {
            limit: Int = 20
        }
        response List<Post>
        error { NotFound(404) }
    }
}
