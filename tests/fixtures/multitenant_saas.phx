// Phoenix Gen — a realistic multi-tenant SaaS control-plane API
//
// TYPE-MODELING NOTES. Conventions used throughout:
//   - Ids use the built-in `Uuid`; timestamps use `DateTime`.
//   - Opaque single-use tokens and the API-key display prefix stay `String`s —
//     they are not UUIDs, so a validated String is the honest model.
//   - Soft-delete is modeled as `Bool deleted` plus `Option<DateTime> deletedAt`
//     (the tombstone time; absent while live).
//   - Tenant scoping appears in two styles across the API: a request header
//     `X-Tenant-Id` (via `as`) on most endpoints, and an explicit `{tenantId}`
//     PATH PARAM on the tenant-rooted resource tree — both are exercised.

// ── Enums (simple unit-variant only, so they codegen on all targets) ──

/** A member's role within an organization, ordered most- to least-privileged */
enum Role { Owner  Admin  Member  Viewer }

/** Lifecycle state of an organization's subscription */
enum PlanTier { Free  Pro  Business  Enterprise }

/** Status of a pending or accepted seat invitation */
enum InviteStatus { Pending  Accepted  Revoked  Expired }

/** Coarse-grained permission scopes a role may be granted */
enum Permission { ReadOnly  Write  Manage  Billing }

// ── Domain types ──────────────────────────────────────────────

/** A tenant organization — the top-level multi-tenancy boundary. Wide struct
 *  carrying identity, plan, audit, and soft-delete fields */
struct Organization {
    /** Opaque org id, also the tenant id */
    id: Uuid
    /** Human-readable display name */
    name: String where self.length > 0 && self.length <= 200
    /** URL-safe slug used in vanity URLs */
    slug: String where self.length > 0 && self.length <= 63
    /** Billing contact email for the tenant */
    billingEmail: String where self.contains("@") && self.length > 3
    plan: PlanTier
    /** Purchased seat count; members may not exceed this */
    seatLimit: Int where self >= 1
    /** Seats currently consumed by active members */
    seatsUsed: Int where self >= 0
    /** Whether the tenant has been suspended (e.g. non-payment) */
    suspended: Bool
    /** Soft-delete tombstone flag */
    deleted: Bool
    /** Tombstone time when soft-deleted; absent while the org is live */
    deletedAt: Option<DateTime>
    /** Creation time */
    createdAt: DateTime
    /** Last-modified time */
    updatedAt: DateTime
    /** Opaque user id of the creator */
    createdBy: Uuid
    /** Arbitrary tenant-level settings as string key/value pairs */
    settings: Map<String, String>
}

/** A workspace (project) nested inside an organization */
struct Workspace {
    /** Opaque workspace id */
    id: Uuid
    /** Owning tenant/org id */
    orgId: Uuid
    name: String where self.length > 0 && self.length <= 120
    /** Optional free-form description */
    description: Option<String> where self.length <= 1000
    /** Whether non-members of the workspace can view it */
    isPublic: Bool
    deleted: Bool
    /** Tombstone time when soft-deleted; absent while live */
    deletedAt: Option<DateTime>
    /** Creation time */
    createdAt: DateTime
    /** Last-modified time */
    updatedAt: DateTime
    /** Opaque user id of the creator */
    createdBy: Uuid
}

/** A member of an organization — a user bound to a tenant with a role.
 *  Wide struct combining identity, role/permission, audit, and soft-delete */
struct Member {
    /** Opaque membership id */
    id: Uuid
    /** Owning tenant/org id */
    orgId: Uuid
    /** Opaque user id behind this membership */
    userId: Uuid
    displayName: String where self.length > 0 && self.length <= 200
    email: String where self.contains("@") && self.length > 3
    role: Role
    /** Effective permission scopes granted to this member */
    permissions: List<Permission>
    /** Whether the member's email/seat has been confirmed */
    active: Bool
    deleted: Bool
    /** Tombstone time when soft-deleted; absent while live */
    deletedAt: Option<DateTime>
    /** Time of last successful sign-in; absent if never signed in */
    lastSeenAt: Option<DateTime>
    /** Creation time */
    createdAt: DateTime
    /** Last-modified time */
    updatedAt: DateTime
    /** Opaque user id of whoever provisioned this member */
    createdBy: Uuid
}

/** A seat invitation extended to a prospective member */
struct Invite {
    /** Opaque invite id */
    id: Uuid
    orgId: Uuid
    email: String where self.contains("@") && self.length > 3
    /** Role the invitee will receive on acceptance */
    role: Role
    status: InviteStatus
    /** Opaque single-use acceptance token (not a UUID — validated String) */
    token: String where self.length > 0
    /** Time after which the invite is no longer valid */
    expiresAt: DateTime
    /** Creation time */
    createdAt: DateTime
    /** Opaque user id of the inviter */
    createdBy: Uuid
}

/** An immutable audit-log entry recording a tenant-scoped action */
struct AuditEvent {
    /** Opaque event id */
    id: Uuid
    orgId: Uuid
    /** Opaque user id of the actor who performed the action */
    actorId: Uuid
    /** Action verb, e.g. "member.invited" */
    action: String where self.length > 0 && self.length <= 120
    /** Type of the affected resource, e.g. "workspace" */
    targetType: String where self.length > 0
    /** Opaque id of the affected resource */
    targetId: Uuid
    /** Occurrence time */
    createdAt: DateTime
    /** Arbitrary structured context as string key/value pairs */
    metadata: Map<String, String>
}

/** An API key issued to a tenant for programmatic access */
struct ApiKey {
    /** Opaque key id */
    id: Uuid
    orgId: Uuid
    /** Human label for the key */
    name: String where self.length > 0 && self.length <= 120
    /** Non-secret display prefix, e.g. "pk_live_" */
    prefix: String where self.length > 0 && self.length <= 16
    /** Scopes this key is allowed to exercise */
    scopes: List<Permission>
    revoked: Bool
    /** Time of last use; absent if never used */
    lastUsedAt: Option<DateTime>
    /** Creation time */
    createdAt: DateTime
    /** Opaque user id of the issuer */
    createdBy: Uuid
}

// ── Organization endpoints (tenant created/listed at the platform root) ──

/** Provision a new tenant organization. The platform admin token authorizes;
 *  server fills id/audit/seat-usage/soft-delete fields */
endpoint createOrganization: POST "/organizations" {
    headers {
        authorization: String
        idemKey: String as "Idempotency-Key"
    }
    body Organization omit {
        id, seatsUsed, suspended, deleted, deletedAt, createdAt, updatedAt
    }
    response Organization
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        Conflict(409)
    }
}

/** Fetch an organization by id */
endpoint getOrganization: GET "/organizations/{id}" {
    headers {
        authorization: String
    }
    response Organization
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

/** List organizations visible to the caller (offset-paginated) */
endpoint listOrganizations: GET "/organizations" {
    headers {
        authorization: String
    }
    query {
        page: Int = 1
        limit: Int = 20
        q: Option<String>
        includeDeleted: Bool = false
    }
    response List<Organization>
    pagination { offset }
    error {
        Unauthorized(401)
        Forbidden(403)
    }
}

/** Partially update an organization. Tenant carried via header; every supplied
 *  field is optional (partial), and immutable/audit fields are omitted */
endpoint updateOrganization: PATCH "/organizations/{id}" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    body Organization omit {
        id, seatsUsed, deleted, deletedAt, createdAt, updatedAt, createdBy
    } partial
    response Organization
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

/** Soft-delete (tombstone) an organization */
endpoint deleteOrganization: DELETE "/organizations/{id}" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
        Conflict(409)
    }
}

// ── Workspaces (tenant-rooted path tree: {tenantId} as a PATH PARAM) ──

/** List a tenant's workspaces (cursor-paginated). Tenant scoping here is via
 *  the {tenantId} PATH PARAM rather than a header */
endpoint listWorkspaces: GET "/tenants/{tenantId}/workspaces" {
    headers {
        authorization: String
    }
    query {
        cursor: Option<String>
        limit: Int = 25
        q: Option<String>
        includeDeleted: Bool = false
    }
    response List<Workspace>
    pagination { cursor }
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

/** Create a workspace under a tenant. Server fills id/orgId/audit/soft-delete */
endpoint createWorkspace: POST "/tenants/{tenantId}/workspaces" {
    headers {
        authorization: String
    }
    body Workspace omit {
        id, orgId, deleted, deletedAt, createdAt, updatedAt
    }
    response Workspace
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        Conflict(409)
    }
}

/** Fetch a workspace by id within a tenant */
endpoint getWorkspace: GET "/tenants/{tenantId}/workspaces/{id}" {
    headers {
        authorization: String
    }
    response Workspace
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

/** Create-or-update a workspace by id (idempotent PUT): returns 200 when an
 *  existing workspace was replaced, 201 when a new one was created. Both carry
 *  the same Workspace body (multi-status block — all typed entries share one
 *  type) */
endpoint upsertWorkspace: PUT "/tenants/{tenantId}/workspaces/{id}" {
    headers {
        authorization: String
    }
    body Workspace omit {
        id, orgId, deleted, deletedAt, createdAt, updatedAt, createdBy
    }
    response {
        200: Workspace
        201: Workspace
    }
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        Conflict(409)
    }
}

/** Rename a workspace — a required new name, plus an optional description
 *  update riding along (pick + selective partial) */
endpoint renameWorkspace: PATCH "/tenants/{tenantId}/workspaces/{id}" {
    headers {
        authorization: String
    }
    body Workspace pick { name, description } partial { description }
    response Workspace
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

// ── Members (tenant carried via X-Tenant-Id header) ──

/** List members of the caller's tenant (offset-paginated), filterable by role */
endpoint listMembers: GET "/members" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
        trace: Option<String> as "X-Trace-Id"
    }
    query {
        page: Int = 1
        limit: Int = 50
        q: Option<String>
        activeOnly: Bool = true
    }
    response List<Member>
    pagination { offset }
    error {
        Unauthorized(401)
        Forbidden(403)
    }
}

/** Fetch a single member by id within the caller's tenant */
endpoint getMember: GET "/members/{id}" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    response Member
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
    }
}

/** Change a member's role and/or permissions (pick: only those two fields) */
endpoint updateMemberRole: PATCH "/members/{id}" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    body Member pick { role, permissions }
    response Member
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
        Conflict(409)
    }
}

/** Remove (soft-delete) a member, freeing their seat */
endpoint removeMember: DELETE "/members/{id}" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    error {
        Unauthorized(401)
        Forbidden(403)
        NotFound(404)
        Conflict(409)
    }
}

// ── Invitations ──

/** Invite a user to the tenant by email. Idempotency-Key guards double-sends */
endpoint createInvite: POST "/invites" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
        idemKey: String as "Idempotency-Key"
    }
    body Invite omit { id, orgId, status, token, createdAt }
    response Invite
    error {
        ValidationError(400)
        Unauthorized(401)
        Forbidden(403)
        Conflict(409)
    }
}

/** List outstanding invites for the tenant (cursor-paginated) */
endpoint listInvites: GET "/invites" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    query {
        cursor: Option<String>
        limit: Int = 20
    }
    response List<Invite>
    pagination { cursor }
    error {
        Unauthorized(401)
        Forbidden(403)
    }
}

/** Accept an invite via its single-use token. Returns the resulting Member,
 *  plus rate-limit info in response headers */
endpoint acceptInvite: POST "/invites/{token}/accept" {
    headers {
        authorization: String
    }
    response Member headers {
        ratelimitRemaining: Int as "X-RateLimit-Remaining"
        requestId: Option<String> as "X-Request-Id"
    }
    error {
        Unauthorized(401)
        NotFound(404)
        Conflict(409)
    }
}

// ── Audit log (read-only, tenant-scoped) ──

/** Stream the tenant's audit log (cursor-paginated), filterable by action */
endpoint listAuditEvents: GET "/audit-events" {
    headers {
        authorization: String
        tenant: String as "X-Tenant-Id"
    }
    query {
        cursor: Option<String>
        limit: Int = 100
        action: Option<String>
        actorId: Option<String>
    }
    response List<AuditEvent>
    pagination { cursor }
    error {
        Unauthorized(401)
        Forbidden(403)
    }
}

// ── API versioning: API-key management under the /v1 prefix ──

/** A versioned slice: tenant API-key management served under the `/v1` prefix */
api version "v1" {
    /** Issue a new API key for the tenant. Server fills id/orgId/audit/state;
     *  the one-time secret itself is returned out of band (not modeled here) */
    endpoint createApiKey: POST "/api-keys" {
        headers {
            authorization: String
            tenant: String as "X-Tenant-Id"
        }
        body ApiKey omit { id, orgId, prefix, revoked, lastUsedAt, createdAt }
        response ApiKey
        error {
            ValidationError(400)
            Unauthorized(401)
            Forbidden(403)
            Conflict(409)
        }
    }

    /** List the tenant's API keys (offset-paginated) */
    endpoint listApiKeys: GET "/api-keys" {
        headers {
            authorization: String
            tenant: String as "X-Tenant-Id"
        }
        query {
            page: Int = 1
            limit: Int = 20
            includeRevoked: Bool = false
        }
        response List<ApiKey>
        pagination { offset }
        error {
            Unauthorized(401)
            Forbidden(403)
        }
    }

    /** Revoke an API key. Returns 200 with the revoked key, or 204 if it was
     *  already revoked (idempotent revoke — multi-status, mixed typed/typeless) */
    endpoint revokeApiKey: DELETE "/api-keys/{id}" {
        headers {
            authorization: String
            tenant: String as "X-Tenant-Id"
        }
        response {
            200: ApiKey
            204
        }
        error {
            Unauthorized(401)
            Forbidden(403)
            NotFound(404)
        }
    }
}
