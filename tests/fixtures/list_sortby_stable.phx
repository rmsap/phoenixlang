// Explicit stability fixture for `List.sortBy`.  Stability matters
// because the documented contract on the Cranelift / interpreter
// merge sort is that `cmp <= 0` keeps the left run first, so equal
// keys preserve their original order.  `list_sortby_strings.phx`
// implicitly relies on stability (apple before grape at length 5),
// but its expected output doesn't *name* stability — a regression
// could be misread as a sort-ordering bug.  This fixture pins the
// invariant directly: if the sort ever became unstable, the output
// would diverge in a way that fingerprints the regression.
//
// Each input element is a struct `Tagged { key, idx }`.  We sort by
// `key` only; `idx` is the original 0..7 input position.  After a
// stable sort, elements with the same key must appear in ascending
// `idx` order.  An unstable sort would shuffle ties.
struct Tagged {
  Int key
  Int idx
}

function main() {
  // Three keys (1, 0, 2) interleaved across eight elements.  Each
  // key bucket has its own original-index sequence:
  //   key=0 → idx 1, 4, 6
  //   key=1 → idx 0, 3, 7
  //   key=2 → idx 2, 5
  // After a stable sort by key, the output should be:
  //   [(0,1), (0,4), (0,6), (1,0), (1,3), (1,7), (2,2), (2,5)]
  let xs: List<Tagged> = [Tagged(1, 0), Tagged(0, 1), Tagged(2, 2), Tagged(1, 3), Tagged(0, 4), Tagged(2, 5), Tagged(0, 6), Tagged(1, 7)]
  let sorted: List<Tagged> = xs.sortBy(function(a: Tagged, b: Tagged) -> Int {
    a.key - b.key
  })
  // Print every (key, idx) pair so any reordering of ties is visible.
  let mut i: Int = 0
  while i < sorted.length() {
    let t: Tagged = sorted.get(i)
    print(t.key)
    print(t.idx)
    i = i + 1
  }
}
