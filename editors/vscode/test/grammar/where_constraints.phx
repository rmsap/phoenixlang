// SYNTAX TEST "source.phoenix"

struct User {
// <- storage.type.phoenix
//     ^^^^ entity.name.type.phoenix
  String name where self.length > 0 and self.length <= 100
//^^^^^^ support.type.primitive.phoenix
//            ^^^^^ keyword.other.endpoint.phoenix
//                  ^^^^ variable.language.self.phoenix
//                                ^ constant.numeric.integer.phoenix
//                                  ^^^ keyword.operator.logical.phoenix
//                                                  ^^ keyword.operator.comparison.phoenix
//                                                     ^^^ constant.numeric.integer.phoenix
  Int age where self >= 0 and self <= 150
//^^^ support.type.primitive.phoenix
//        ^^^^^ keyword.other.endpoint.phoenix
//              ^^^^ variable.language.self.phoenix
//                   ^^ keyword.operator.comparison.phoenix
//                      ^ constant.numeric.integer.phoenix
//                        ^^^ keyword.operator.logical.phoenix
}
