{
  "name": "phoenixlang",
  "displayName": "Phoenix Language",
  "description": "Syntax highlighting and language support for the Phoenix programming language. Automatically downloads the Phoenix language server for hover, autocomplete, go-to-definition, and more.",
  "version": "0.1.3",
  "publisher": "rmsap",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmsap/phoenixlang"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:phoenix"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "phoenix",
        "aliases": [
          "Phoenix",
          "phoenix"
        ],
        "extensions": [
          ".phx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "phoenix",
        "scopeName": "source.phoenix",
        "path": "./syntaxes/phoenix.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Phoenix",
      "properties": {
        "phoenix.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the phoenix-lsp language server binary. Leave empty to download automatically."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "test": "vitest run",
    "test:grammar": "vscode-tmgrammar-snap -s source.phoenix -g syntaxes/phoenix.tmLanguage.json test/grammar/*.phx"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
