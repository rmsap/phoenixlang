{
  "name": "phoenix-lang",
  "displayName": "Phoenix Lang",
  "description": "Syntax highlighting and language server for the Phoenix programming language",
  "version": "0.1.0",
  "publisher": "rmsap",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmsap/phoenixlang"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:phoenix"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "phoenix",
        "aliases": [
          "Phoenix",
          "phoenix"
        ],
        "extensions": [
          ".phx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "phoenix",
        "scopeName": "source.phoenix",
        "path": "./syntaxes/phoenix.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Phoenix",
      "properties": {
        "phoenix.lspPath": {
          "type": "string",
          "default": "phoenix-lsp",
          "description": "Path to the phoenix-lsp language server binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:grammar": "vscode-tmgrammar-snap -s source.phoenix -g syntaxes/phoenix.tmLanguage.json test/grammar/*.phx"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
